# ─────────────────────────────────────────────────────────────────────────────
#  Configuration for the Model Governance & Validation Framework
#
#  EVERYTHING WORKS WITHOUT A KEY. With no OPENAI_API_KEY set, the app runs in
#  SIMULATED mode: every screen works, and the GenAI (Track B) tests return
#  clearly-labelled illustrative results at ZERO cost.
#
#  To run the GENUINE live tests in Track B, copy this file to ".env",
#  paste an OpenAI API key below, and restart the app.
# ─────────────────────────────────────────────────────────────────────────────

# Your OpenAI API key. Leave blank to stay in simulated mode.
OPENAI_API_KEY=

# The model that plays the "banking chatbot under test".
# gpt-4o-mini is cheap and fast and is a sensible default for a demo.
OPENAI_CHATBOT_MODEL=gpt-4o-mini

# The model used as the impartial "LLM-as-judge" that scores open-ended answers.
OPENAI_JUDGE_MODEL=gpt-4o-mini
