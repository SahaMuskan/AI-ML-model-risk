# ─────────────────────────────────────────────────────────────────────────────
#  Model Risk Studio — configuration
#
#  EVERYTHING WORKS WITHOUT A KEY. With no credentials set, the app runs in
#  SIMULATED mode: every screen works, and Track B (GenAI validation) returns
#  clearly-labelled illustrative results at ZERO cost.
#
#  To run GENUINE live Track B tests, copy this file to ".env", fill in the
#  section for your LLM provider, and restart the app.
# ─────────────────────────────────────────────────────────────────────────────

# ── Select your LLM provider ──────────────────────────────────────────────────
# Options:  openai  |  azure  |  custom
# Leave blank to use OpenAI direct (the original default).
LLM_PROVIDER=openai


# ── Option A: OpenAI direct (default) ────────────────────────────────────────
OPENAI_API_KEY=

# Model names — gpt-4o-mini is cheap and fast; a full Track B run costs pennies.
OPENAI_CHATBOT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini


# ── Option B: Azure OpenAI ────────────────────────────────────────────────────
# Set LLM_PROVIDER=azure above, then fill these in.
#
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# OPENAI_API_KEY=<your Azure OpenAI key>
# AZURE_OPENAI_API_VERSION=2024-02-01
#
# OPENAI_CHATBOT_MODEL=<your deployment name, e.g. gpt-4o-mini>
# OPENAI_JUDGE_MODEL=<your deployment name>


# ── Option C: Internal LLM Gateway / LLM Garden (OpenAI-compatible proxy) ────
# Set LLM_PROVIDER=custom above, then fill these in.
#
# OPENAI_BASE_URL=https://llm-gateway.internal.yourbank.com/v1
# OPENAI_API_KEY=<gateway key or service-account token>
#
# OPENAI_CHATBOT_MODEL=<model name as your proxy calls it>
# OPENAI_JUDGE_MODEL=<model name as your proxy calls it>
